# URL del backend en Railway (sustituye por tu URL real tras el despliegue)
BACKEND_URL=https://TU-BACKEND.railway.app

# Identificador de este dispositivo NFC (puede dejarse así)
DEVICE_ID=device-oficina-01

# Clave secreta que debe coincidir con DEVICE_API_KEY en el backend
DEVICE_API_KEY=cambia-esto-por-una-clave-segura

# Modo de lectura NFC
USE_STUB=false
USE_KEYBOARD_GLOBAL=true

# Intervalo de sincronización offline en segundos
SYNC_INTERVAL=30
